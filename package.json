{
  "name": "@sauravbhattacharya001/biobots",
  "version": "1.2.0",
  "description": "Bioprinting computation toolkit — material calculation, rheology modeling, GCode analysis, cell viability estimation, and cross-linking kinetics",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "docs/shared/*.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "bioprinting",
    "biobots",
    "rheology",
    "gcode",
    "tissue-engineering",
    "cell-viability",
    "bioink",
    "material-science"
  ],
  "scripts": {
    "test": "jest --verbose --coverage",
    "test:ci": "jest --verbose --coverage --coverageReporters=text --coverageReporters=lcov --coverageReporters=json-summary",
    "coverage": "jest --coverage --coverageReporters=text --coverageReporters=lcov --coverageReporters=json-summary --coverageReporters=html",
    "coverage:check": "jest --coverage --coverageReporters=text-summary",
    "prepublishOnly": "npm test",
    "preversion": "npm test",
    "postversion": "git push && git push --tags"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": ["./jest.setup.js"],
    "collectCoverageFrom": [
      "index.js",
      "docs/shared/**/*.js",
      "Try/scripts/**/*.js",
      "!Try/scripts/ai.*.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "json-summary"
    ],
    "coverageThresholds": {
      "global": {
        "branches": 60,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sauravbhattacharya001/BioBots.git"
  },
  "license": "MIT",
  "devDependencies": {
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0"
  }
}
